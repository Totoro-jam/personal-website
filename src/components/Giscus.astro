---
import { giscusConfig } from "@/giscus.config";

const { repo, repoId, category, categoryId } = giscusConfig;
const isConfigured = repo && repoId && categoryId;
---

{
  isConfigured && (
    <section class="giscus mt-12 border-t pt-8">
      <h2 class="mb-4 text-xl font-semibold">Comments</h2>
      <script
        is:inline
        src="https://giscus.app/client.js"
        data-repo={repo}
        data-repo-id={repoId}
        data-category={category}
        data-category-id={categoryId}
        data-mapping="pathname"
        data-strict="0"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="bottom"
        data-theme="preferred_color_scheme"
        data-lang="en"
        data-loading="lazy"
        crossorigin="anonymous"
        async
      ></script>
    </section>
  )
}
