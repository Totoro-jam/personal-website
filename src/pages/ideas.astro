---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Datetime from "@/components/Datetime.astro";
import { useTranslations } from "@/i18n";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const rawIdeas = await getCollection("ideas");
const ideas = rawIdeas
  .filter(({ data }) => !data.draft)
  .sort(
    (a, b) =>
      new Date(b.data.pubDatetime).getTime() -
      new Date(a.data.pubDatetime).getTime()
  );
---

<Layout title={`${t.pages.ideasTitle} | ${config.site.title}`} description={t.pages.ideasDesc}>
  <Header />
  <main id="main-content" class="app-layout mt-8" data-pagefind-body>
    <h1 class="text-accent text-3xl font-bold">{t.pages.ideasTitle}</h1>
    <p class="text-muted-foreground mt-2 mb-8">{t.pages.ideasDesc}</p>
    {
      ideas.length === 0 ? (
        <p class="text-muted-foreground">暂无内容，灵感正在赶来...</p>
      ) : (
        <ul class="flex flex-col gap-4">
          {ideas.map(idea => (
            <li class="my-4">
              <a
                href={`/ideas/${idea.id}`}
                class="text-accent inline-block text-lg font-medium decoration-dashed underline-offset-4 hover:underline"
              >
                {idea.data.title}
              </a>
              <p class="text-muted-foreground text-sm">{idea.data.description}</p>
              <Datetime pubDatetime={idea.data.pubDatetime} size="sm" />
            </li>
          ))}
        </ul>
      )
    }
  </main>
  <Footer />
</Layout>
