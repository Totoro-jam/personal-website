---
import { getCollection } from "astro:content";

import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import Socials from "@/components/Socials.astro";
import Layout from "@/layouts/Layout.astro";

const posts = await getCollection("posts");
const published = posts.filter(({ data }) => !data.draft).length;
---

<Layout>
  <Header />
  <main id="main-content" class="app-layout mt-16 sm:mt-24" data-pagefind-body>
    <div class="mx-auto max-w-2xl">
      <h1 class="text-accent text-4xl font-bold tracking-tight sm:text-5xl">
        Hi, I'm Totoro 👋
      </h1>
      <p class="text-muted-foreground mt-6 text-lg leading-relaxed">
        Welcome aboard the Voyage Log — my corner of the web where I write about
        technology, share projects, and document the journey.
      </p>
      <p class="text-muted-foreground mt-4 text-lg leading-relaxed">
        A late wind is still a wind — long voyage. ⛵️
      </p>

      <div class="mt-12 grid grid-cols-2 gap-4 sm:grid-cols-4">
        <a
          href="/posts"
          class="border-border hover:border-accent rounded-lg border p-4 text-center transition-colors"
        >
          <div class="text-accent text-2xl font-bold">{published}</div>
          <div class="text-muted-foreground text-sm">Posts</div>
        </a>
        <a
          href="/notes"
          class="border-border hover:border-accent rounded-lg border p-4 text-center transition-colors"
        >
          <div class="text-accent text-2xl font-bold">0</div>
          <div class="text-muted-foreground text-sm">Notes</div>
        </a>
        <a
          href="/sparks"
          class="border-border hover:border-accent rounded-lg border p-4 text-center transition-colors"
        >
          <div class="text-accent text-2xl font-bold">0</div>
          <div class="text-muted-foreground text-sm">Sparks</div>
        </a>
        <a
          href="/projects"
          class="border-border hover:border-accent rounded-lg border p-4 text-center transition-colors"
        >
          <div class="text-accent text-2xl font-bold">0</div>
          <div class="text-muted-foreground text-sm">Projects</div>
        </a>
      </div>

      <div class="mt-12">
        <Socials />
      </div>
    </div>
  </main>
  <Footer />
</Layout>
