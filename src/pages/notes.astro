---
import { getCollection } from "astro:content";

import Datetime from "@/components/Datetime.astro";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import config from "@/config";
import { useTranslations } from "@/i18n";
import Layout from "@/layouts/Layout.astro";

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const raw = await getCollection("notes");
const notes = raw
  .filter(({ data }) => !data.draft)
  .sort(
    (a, b) =>
      new Date(b.data.pubDatetime).getTime() -
      new Date(a.data.pubDatetime).getTime()
  );
---

<Layout
  title={`${t.pages.notesTitle} | ${config.site.title}`}
  description={t.pages.notesDesc}
>
  <Header />
  <main id="main-content" class="app-layout mt-8" data-pagefind-body>
    <h1 class="text-accent text-3xl font-bold">{t.pages.notesTitle}</h1>
    <p class="text-muted-foreground mt-2 mb-8">{t.pages.notesDesc}</p>
    {
      notes.length === 0 ? (
        <p class="text-muted-foreground">笔记整理中...</p>
      ) : (
        <ul class="flex flex-col gap-4">
          {notes.map(n => (
            <li class="my-4">
              <a
                href={`/notes/${n.id}`}
                class="text-accent inline-block text-lg font-medium decoration-dashed underline-offset-4 hover:underline"
              >
                {n.data.title}
              </a>
              <p class="text-muted-foreground text-sm">{n.data.description}</p>
              <Datetime pubDatetime={n.data.pubDatetime} size="sm" />
            </li>
          ))}
        </ul>
      )
    }
  </main>
  <Footer />
</Layout>
