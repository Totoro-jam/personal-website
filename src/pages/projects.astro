---
import { getCollection } from "astro:content";

import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import config from "@/config";
import Layout from "@/layouts/Layout.astro";
import { ui } from "@/ui-strings";

const locale = Astro.currentLocale ?? config.site.lang;
const t = ui;

const projects = await getCollection("projects");
---

<Layout
  title={`${t.pages.projectsTitle} | ${config.site.title}`}
  description={t.pages.projectsDesc}
>
  <Header />
  <main id="main-content" class="app-layout mt-8" data-pagefind-body>
    <h1 class="text-accent text-3xl font-bold">{t.pages.projectsTitle}</h1>
    <p class="text-muted-foreground mt-2 mb-8">{t.pages.projectsDesc}</p>
    {
      projects.length === 0 ? (
        <p class="text-muted-foreground">舰队正在建造中...</p>
      ) : (
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          {projects.map(p => (
            <a
              href={
                (p.data.url ?? p.data.github)
                  ? `https://github.com/${p.data.github}`
                  : "#"
              }
              class="border-border hover:border-accent block rounded-lg border p-4 transition-colors"
            >
              <h2 class="text-lg font-semibold">{p.data.name}</h2>
              <p class="text-muted-foreground mt-1 text-sm">
                {locale === "zh"
                  ? p.data.description
                  : (p.data.descriptionEn ?? p.data.description)}
              </p>
            </a>
          ))}
        </div>
      )
    }
  </main>
  <Footer />
</Layout>
